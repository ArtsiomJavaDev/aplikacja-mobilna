# Skopiuj do .env i ustaw prawdziwe wartości. Plik .env nie trafia do repozytorium.
# Nigdy nie wpisuj prawdziwych kluczy ani haseł w plikach committowanych.

POSTGRES_PASSWORD=ustaw_haslo_do_bazy
JWT_SECRET=wygeneruj_bezpieczny_klucz_min_32_znaki
TESTING_APP_SECRET=min_64_znakow_dla_testow_aplikacji

