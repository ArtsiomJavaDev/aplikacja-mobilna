{
  "expo": {
    "name": "Crypto Exchange",
    "slug": "projectapi-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "projectapi",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.projectapi.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Aplikacja używa kamery do skanowania.",
        "NSPhotoLibraryUsageDescription": "Aplikacja potrzebuje dostępu do galerii.",
        "NSLocationWhenInUseUsageDescription": "Aplikacja używa lokalizacji do wyświetlania regionu."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.projectapi.mobile",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Aplikacja potrzebuje dostępu do zdjęć.",
          "cameraPermission": "Aplikacja potrzebuje dostępu do kamery."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Aplikacja używa lokalizacji do wyświetlania regionu."
        }
      ],
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
