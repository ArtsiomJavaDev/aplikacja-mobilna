# Adres backendu API (Spring Boot). Backend musi być włączony: docker compose up
# Skopiuj do .env i ustaw odpowiedni adres:
#
# Przeglądarka (web):           http://localhost:8081
# Emulator Android:             http://10.0.2.2:8081
# Telefon/tablet w Wi‑Fi:       http://IP_KOMPUTERA:8081
#   (IP komputera: Windows → ipconfig → IPv4, np. 192.168.1.5)
#
# Po zmianie .env uruchom ponownie: npx expo start -c
EXPO_PUBLIC_API_URL=http://localhost:8081
